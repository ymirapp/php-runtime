{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "bootstrap-sha": "53c85b142f6383f0e3a8168022b39eec30a95306",
    "always-update": true,
    "plugins": [ "sentence-case" ],
    "skip-github-release": true,
    "packages": {
        ".": {
            "release-type": "php",
            "pull-request-title-pattern": "chore: release ${version}",
            "extra-files": [
                {
                    "type": "generic",
                    "path": "runtime/php-72/Dockerfile"
                },
                {
                    "type": "generic",
                    "path": "runtime/php-73/Dockerfile"
                },
                {
                    "type": "generic",
                    "path": "runtime/php-74/Dockerfile"
                },
                {
                    "type": "generic",
                    "path": "runtime/php-80/Dockerfile"
                },
                {
                    "type": "generic",
                    "path": "runtime/php-81/Dockerfile"
                },
                {
                    "type": "generic",
                    "path": "runtime/php-82/Dockerfile"
                },
                {
                    "type": "generic",
                    "path": "runtime/php-83/Dockerfile"
                },
                {
                    "type": "generic",
                    "path": "runtime/php-84/Dockerfile"
                },
                {
                    "type": "generic",
                    "path": "runtime/php-85/Dockerfile"
                }
            ],
            "changelog-sections": [
                { "type" :"feat", "section" :"Features", "hidden": false },
                { "type":"fix", "section": "Bug Fixes", "hidden": false },
                { "type": "deps", "section": "Dependency Changes", "hidden": false },
                { "type":"chore", "section": "Miscellaneous" ,"hidden":true }
            ]
        }
    }
}
